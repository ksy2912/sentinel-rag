# Copy to .env for local Docker. On Render, set secrets in the dashboard.

ALLOW_MOCK_LLM=false

# LLM (required for /ask)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_HTTP_REFERER=http://localhost
OPENROUTER_APP_TITLE=sentinel-rag

# Embeddings — local Docker uses Ollama; cloud deploy uses OpenAI
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
EMBEDDING_DIM=768
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# Optional Langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
